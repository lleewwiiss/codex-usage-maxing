{
  "name": "codex-usage-maxing",
  "version": "0.1.1",
  "description": "Experimental Codex quota daemon for calculated tech-debt PRs.",
  "homepage": "https://github.com/lleewwiiss/codex-usage-maxing#readme",
  "bugs": {
    "url": "https://github.com/lleewwiiss/codex-usage-maxing/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lleewwiiss/codex-usage-maxing.git"
  },
  "bin": {
    "codex-usage-maxing": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun test",
    "dev": "bun run src/cli.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.2.1",
    "@types/bun": "latest",
    "@types/node": "latest",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.8"
}
